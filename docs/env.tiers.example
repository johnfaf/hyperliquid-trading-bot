# =====================================================================
# env.tiers.example -- Railway env-var recipes for the scaling ladder
# =====================================================================
#
# Paste ONE of the tier blocks below into Railway's Variables UI (or set
# via `railway variables --set KEY=value`) when advancing up the ladder.
#
# Companion doc: docs/SCALING_RUNBOOK.md (advance gates, retreat path,
# verification checklist).
#
# Rule of thumb: advance ONE rung at a time.  The whole point of the
# ladder is that each rung tells you something the previous rung
# couldn't (fee drag, slippage at size, fill latency, regime response).
# Skipping rungs = flying blind with real capital.
# =====================================================================


# ─── ALWAYS SET (prerequisites) ──────────────────────────────────────
#
# Nothing trades without these two.  Leave them in place across every
# tier change.  They're the dual-control lock.

LIVE_TRADING_ENABLED=true
LIVE_TRADING_DUAL_CONTROL_CONFIRM=true


# ─── T0: canary (START HERE) ─────────────────────────────────────────
#
# Default state.  Tier caps to $25/order, $50 daily loss, $50/coin,
# 25 signals/day, kelly_dampen=0.5.  Run at least 2 days.

LIVE_TIER=T0

# Optional: if you were running the legacy canary and want to keep the
# old env vars as belt-and-braces, they'll be harmlessly ignored when
# LIVE_TIER is set -- the tier's limits are always tighter or equal.
# LIVE_CANARY_MODE=true
# LIVE_CANARY_MAX_ORDER_USD=25.0
# LIVE_CANARY_MAX_SIGNALS_PER_DAY=25


# ─── T1: seed (after T0 checklist passes) ────────────────────────────
#
# Tier caps to $50/order, $100 daily loss, $150/coin, 40 signals/day,
# kelly_dampen=0.65.  Run at least 3 days.
#
# That's the only change from T0 -- leave everything else alone.

LIVE_TIER=T1


# ─── T2: growth (after T1 checklist passes) ──────────────────────────
#
# Tier caps to $100/order, $250 daily loss, $500/coin, 60 signals/day,
# kelly_dampen=0.8.  Run at least 5 days.

LIVE_TIER=T2


# ─── T3: scale (after T2 checklist passes) ───────────────────────────
#
# Tier caps to $250/order, $600 daily loss, $1,500/coin,
# 100 signals/day, kelly_dampen=0.9.  Run at least 7 days.

LIVE_TIER=T3


# ─── T4: full scale (after T3 checklist passes, ~17+ days from T0) ───
#
# T4 DISABLES all tier overrides.  The env vars below are the only
# ceiling -- set ALL of them atomically or the effective caps drop back
# to whatever's in your environment from earlier tiers.
#
# Recommended starting envelope for a retail book reaching T4.  Tune
# the numbers to your own capital, drawdown tolerance, and daily burn
# rate.  Raise them gradually over further weeks, not days.

LIVE_TIER=T4
LIVE_MAX_ORDER_USD=500
HL_MAX_DAILY_LOSS=1000
LIVE_MAX_POSITION_SIZE_USD=3000
LIVE_CANARY_MAX_SIGNALS_PER_DAY=150
KELLY_MULTIPLIER=0.25


# ─── Emergency brake (any time) ──────────────────────────────────────
#
# Drop back to canary without touching anything else.  Restart and the
# next order is capped at $25.  Use this if you see trouble and want
# to keep trading while you diagnose.

LIVE_TIER=T0


# ─── Kill all live trading (any time) ────────────────────────────────
#
# Flip either of these and restart.  The bot loads paper-only.
#
# LIVE_TRADING_ENABLED=false
# LIVE_TRADING_DUAL_CONTROL_CONFIRM=false


# ─── Supporting vars (rarely change) ─────────────────────────────────
#
# These are already set in your environment from PR-A/PR-B.  Listed
# here for visibility only.  Don't change them as part of a tier flip
# -- tier advancement is one variable at a time (LIVE_TIER), everything
# else stays pinned.
#
# LIVE_KILL_SWITCH_STATE_FILE=/data/live_kill_switch_state.json
# LIVE_EXTERNAL_KILL_SWITCH_FILE=/data/external_kill.flag
# LIVE_ORDER_DEDUP_WINDOW_S=30
# LIVE_EMERGENCY_CLOSE_RETRIES=3
# LIVE_PROTECTIVE_ORDER_RETRIES=3
# LIVE_FILL_VERIFY_TIMEOUT_S=10.0
# LIVE_MIN_ORDER_USD=11.0
# LIVE_LEVERAGE_IS_CROSS=true
# HL_MAX_POSITION_SIZE=<same as LIVE_MAX_POSITION_SIZE_USD>
# DB_BACKEND=dualwrite
# DB_MIN_FREE_MB=100


# ─── Verification after every tier flip ──────────────────────────────
#
# After setting LIVE_TIER and restarting the service, hit /healthz and
# confirm the numbers match the tier.  Example for T2:
#
#   GET /healthz  →  {
#     "active_tier": {
#       "name": "T2",
#       "label": "growth",
#       "max_order_usd": 100.0,
#       "max_daily_loss_usd": 250.0,
#       "max_position_size_usd": 500.0,
#       "max_signals_per_day": 60,
#       "kelly_dampen": 0.8
#     },
#     "max_order_usd": 100.0,           ← MUST equal active_tier.max_order_usd
#     "daily_pnl_limit": 250.0,         ← MUST equal active_tier.max_daily_loss_usd
#     "max_position_size": 500.0,       ← MUST equal active_tier.max_position_size_usd
#     "canary_mode": true,              ← true for T0-T3, false for T4
#     "kelly_dampen": 0.8
#   }
#
# If any of the ← lines doesn't match the tier, STOP trading and find
# the override before the first order ships.  Common causes: an older
# LIVE_MAX_ORDER_USD set lower than the tier's cap (operator env wins
# on the downside, which is correct behaviour but can surprise you).


# ─── Railway CLI quick commands ──────────────────────────────────────
#
# List current variables:
#   railway variables
#
# Set a single variable (and redeploy):
#   railway variables --set LIVE_TIER=T1
#
# Set multiple atomically (for the T4 transition):
#   railway variables \
#     --set LIVE_TIER=T4 \
#     --set LIVE_MAX_ORDER_USD=500 \
#     --set HL_MAX_DAILY_LOSS=1000 \
#     --set LIVE_MAX_POSITION_SIZE_USD=3000 \
#     --set LIVE_CANARY_MAX_SIGNALS_PER_DAY=150 \
#     --set KELLY_MULTIPLIER=0.25
#
# Roll back (emergency):
#   railway variables --set LIVE_TIER=T0
